# ============================================
# RAILWAY PRODUCTION ENVIRONMENT VARIABLES
# ============================================
# Copia este archivo a .env.production y completa los valores
# NO subas .env.production a GitHub

# ============================================
# NODE ENVIRONMENT
# ============================================
NODE_ENV=production

# ============================================
# DATABASE (Railway crea esto automáticamente)
# ============================================
# Railway agregará esto automáticamente cuando agregues PostgreSQL
# DATABASE_URL=postgresql://user:password@host:5432/landscape_db

# ============================================
# JWT & AUTHENTICATION
# ============================================
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-here-min-32-chars-long

# ============================================
# MANUS OAUTH CONFIGURATION
# ============================================
VITE_APP_ID=your-app-id-from-manus
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://auth.manus.im

# ============================================
# OWNER INFORMATION
# ============================================
OWNER_OPEN_ID=your-owner-open-id
OWNER_NAME=Your Name

# ============================================
# MANUS BUILT-IN FORGE API
# ============================================
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=your-forge-api-key-from-manus
VITE_FRONTEND_FORGE_API_KEY=your-frontend-forge-key
VITE_FRONTEND_FORGE_API_URL=https://forge.manus.im

# ============================================
# APPLICATION BRANDING
# ============================================
VITE_APP_TITLE=LandscapeApp
VITE_APP_LOGO=https://your-cdn-url/logo.png

# ============================================
# ANALYTICS (OPTIONAL)
# ============================================
VITE_ANALYTICS_ENDPOINT=https://analytics.manus.im
VITE_ANALYTICS_WEBSITE_ID=your-website-id

# ============================================
# PORT (Railway asigna automáticamente)
# ============================================
# No necesitas configurar esto - Railway lo asigna automáticamente
# PORT=3000

# ============================================
# OPTIONAL: S3 STORAGE (si usas almacenamiento externo)
# ============================================
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=your-bucket-name

# ============================================
# OPTIONAL: EMAIL CONFIGURATION
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@landscapeapp.com

# ============================================
# OPTIONAL: STRIPE PAYMENT (si implementas pagos)
# ============================================
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
